<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--  DrawerPage top bar  -->
    <StaticResource x:Key="DrawerPageTopBarMinHeight" ResourceKey="SemiHeightControlDefault" />
    <StaticResource x:Key="DrawerPageTopBarSmallHeight" ResourceKey="SemiHeightControlSmall" />
    <StaticResource x:Key="DrawerPageTopBarLargeHeight" ResourceKey="SemiHeightControlLarge" />
    <Thickness x:Key="DrawerPageTopBarPadding">4 0</Thickness>
    <Thickness x:Key="DrawerPageTopBarBorderThickness">0 0 0 1</Thickness>
    <StaticResource x:Key="DrawerPageTopBarCornerRadius" ResourceKey="SemiBorderRadiusSmall" />

    <!--  DrawerPage pane/drawer  -->
    <x:Double x:Key="DrawerPageDrawerLength">280</x:Double>
    <x:Double x:Key="DrawerPageCompactDrawerLength">56</x:Double>

    <!--  DrawerPage pane button  -->
    <StaticResource x:Key="DrawerPagePaneButtonSize" ResourceKey="SemiHeightControlDefault" />
    <StaticResource x:Key="DrawerPagePaneButtonSmallSize" ResourceKey="SemiHeightControlSmall" />
    <StaticResource x:Key="DrawerPagePaneButtonLargeSize" ResourceKey="SemiHeightControlLarge" />
    <Thickness x:Key="DrawerPagePaneButtonMargin">8 0</Thickness>
    <StaticResource x:Key="DrawerPageMenuGlyph" ResourceKey="SemiIconMenu" />
    <StaticResource x:Key="DrawerPageCloseGlyph" ResourceKey="SemiIconClose" />
</ResourceDictionary>
