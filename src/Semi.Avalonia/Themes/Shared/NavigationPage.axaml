<ResourceDictionary xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--  NavigationPage  -->
    <StaticResource x:Key="NavigationPageBarMinHeight" ResourceKey="SemiHeightControlDefault" />
    <StaticResource x:Key="NavigationPageBarSmallHeight" ResourceKey="SemiHeightControlSmall" />
    <StaticResource x:Key="NavigationPageBarLargeHeight" ResourceKey="SemiHeightControlLarge" />
    <Thickness x:Key="NavigationPageBarPadding">4 0</Thickness>
    <Thickness x:Key="NavigationPageBarBorderThickness">0 0 0 1</Thickness>
    <StaticResource x:Key="NavigationPageBarCornerRadius" ResourceKey="SemiBorderRadiusSmall" />
    <StaticResource x:Key="NavigationPageBackButtonGlyph" ResourceKey="SemiIconChevronLeft" />
</ResourceDictionary>
