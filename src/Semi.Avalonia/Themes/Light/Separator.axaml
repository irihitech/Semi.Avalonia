<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <SolidColorBrush x:Key="SeparatorBackground" Opacity="0.2" Color="#1C1F23" />
    <sys:Double x:Key="SeparatorWidth">1</sys:Double>
    <Thickness x:Key="SeparatorMargin">12 4</Thickness>
</ResourceDictionary>
