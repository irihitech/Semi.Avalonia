<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Design.PreviewWith>
        <TabbedPage Width="400" Height="300" />
    </Design.PreviewWith>

    <ControlTheme x:Key="{x:Type TabbedPage}" TargetType="TabbedPage">
        <Setter Property="Background" Value="{DynamicResource TabbedPageBackground}" />
        <Setter Property="Template">
            <ControlTemplate TargetType="TabbedPage">
                <TabControl
                    Name="PART_TabControl"
                    Background="{TemplateBinding Background}"
                    Theme="{StaticResource LineTabControl}"
                    ItemsSource="{TemplateBinding Pages}" />
            </ControlTemplate>
        </Setter>

        <!--  Forward TabPlacement to inner TabControl.TabStripPlacement  -->
        <Style Selector="^[TabPlacement=Top] /template/ TabControl#PART_TabControl">
            <Setter Property="TabStripPlacement" Value="Top" />
        </Style>
        <Style Selector="^[TabPlacement=Bottom] /template/ TabControl#PART_TabControl">
            <Setter Property="TabStripPlacement" Value="Bottom" />
        </Style>
        <Style Selector="^[TabPlacement=Left] /template/ TabControl#PART_TabControl">
            <Setter Property="TabStripPlacement" Value="Left" />
        </Style>
        <Style Selector="^[TabPlacement=Right] /template/ TabControl#PART_TabControl">
            <Setter Property="TabStripPlacement" Value="Right" />
        </Style>
    </ControlTheme>
</ResourceDictionary>
